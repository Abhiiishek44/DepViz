{
  "name": "code-graph-mvp",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main/main/index.js",
  "scripts": {
    "build:main": "rm -rf dist/main && tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json",
    "dev": "npm run build:main && concurrently -k \"vite\" \"wait-on http://localhost:5173 && VITE_DEV_SERVER_URL=http://localhost:5173 electron . --no-sandbox\"",
    "build": "npm run build:main && vite build",
    "start": "electron . --no-sandbox",
    "lint": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.preload.json --noEmit && tsc -p tsconfig.json --noEmit",
    "extract-arch": "npx ts-node --compiler-options '{\"module\":\"commonjs\",\"esModuleInterop\":true}' scripts/run_extraction.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.11.5",
    "chokidar": "^3.6.0",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "dot-env": "^0.0.1",
    "dotenv": "^17.4.2",
    "electron": "^30.0.0",
    "env": "^0.0.2",
    "generative-ai": "^0.1.4",
    "lucide-react": "^1.14.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reactflow": "^11.11.4",
    "tailwind-merge": "^3.5.0",
    "ts-morph": "^28.0.0",
    "zod": "^3.25.76",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@types/dagre": "^0.7.54",
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.5.4",
    "vite": "^5.3.4",
    "wait-on": "^7.2.0"
  }
}
