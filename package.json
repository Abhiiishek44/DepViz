{
  "name": "code-graph-mvp",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "build:main": "tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json",
    "dev": "npm run build:main && concurrently -k \"vite\" \"wait-on http://localhost:5173 && VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build": "npm run build:main && vite build",
    "start": "electron .",
    "lint": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.preload.json --noEmit && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "dagre": "^0.8.5",
    "electron": "^30.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reactflow": "^11.11.4",
    "ts-morph": "^28.0.0"
  },
  "devDependencies": {
    "@types/dagre": "^0.7.54",
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.5.4",
    "vite": "^5.3.4",
    "wait-on": "^7.2.0"
  }
}
